void NodeEditor::CameraControls()
{
    ImGuiIO &io = ImGui::GetIO();
    CameraScaleX_target += -io.MouseWheel * (CameraScaleX * 0.3f);
    CameraScaleX_target = glm::clamp(CameraScaleX_target, 0.25f, 5.0f);
    CameraScaleX =
        std::lerp(CameraScaleX, CameraScaleX_target, RainfallEditor::Get().GetDeltaTime() * 20.0f);

    if (node_editorWindow->Rect().Contains(ImGui::GetMousePos()) &&
        ImGui::IsMouseDragging(ImGuiMouseButton_Middle))
    {

        ImVec2 delta = io.MouseDelta;

        CameraPos -= Screen2Map(delta / 2.0f, true, false);
    }
}

bool NodeEditor::Draw(const std::string_view label, ImVec2 size)
{
    ImGuiWindow *window = ImGui::GetCurrentWindow();
    if (window->SkipItems)
        return false;
    if (ImGui::BeginChild(label.data(), {0, 0},
                          ImGuiChildFlags_Borders | ImGuiChildFlags_NavFlattened,
                          ImGuiWindowFlags_NoScrollbar))
    {
        node_editorWindow = ImGui::GetCurrentWindow();
        CameraControls();
        DrawNodes();
        NodeSearch();
    }

    ImGui::EndChild();
    return true;
