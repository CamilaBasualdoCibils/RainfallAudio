{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build RainfallEditor",
            "type": "shell",
            "command": "cmake --build build --target RainfallEditor --parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake Configure"
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake -S . -B build",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}
